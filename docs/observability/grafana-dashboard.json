{
  "dashboard": {
    "title": "Pulsar Agentic Observability",
    "description": "Comprehensive monitoring dashboard for pulsar-agentic module",
    "tags": ["pulsar", "agentic", "observability"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Agent Execution Overview",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(rate(agent_started_total[5m]))",
            "legendFormat": "Started/sec"
          },
          {
            "expr": "sum(rate(agent_completed_total[5m]))",
            "legendFormat": "Completed/sec"
          },
          {
            "expr": "sum(rate(agent_failed_total[5m]))",
            "legendFormat": "Failed/sec"
          }
        ]
      },
      {
        "id": 2,
        "title": "Active Agents",
        "type": "gauge",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "agent_active_count"
          }
        ],
        "options": {
          "maxValue": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 80, "color": "red" }
            ]
          }
        }
      },
      {
        "id": 3,
        "title": "Agent Success Rate",
        "type": "graph",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 4 },
        "targets": [
          {
            "expr": "sum(rate(agent_completed_total[5m])) / sum(rate(agent_started_total[5m]))",
            "legendFormat": "Success Rate"
          }
        ],
        "yaxes": [
          { "format": "percentunit", "min": 0, "max": 1 }
        ]
      },
      {
        "id": 4,
        "title": "Tool Call Metrics",
        "type": "graph",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(tool_calls_total[5m])) by (tool_name)",
            "legendFormat": "{{tool_name}}"
          }
        ],
        "legend": { "show": true, "rightSide": false }
      },
      {
        "id": 5,
        "title": "Tool Execution Duration (p95)",
        "type": "graph",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(tool_execution_duration_seconds_bucket[5m])) by (tool_name, le))",
            "legendFormat": "{{tool_name}} p95"
          }
        ],
        "yaxes": [
          { "format": "s" }
        ]
      },
      {
        "id": 6,
        "title": "LLM Inference Rate",
        "type": "graph",
        "gridPos": { "x": 0, "y": 10, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(inference_calls_success[5m])) by (model_name)",
            "legendFormat": "{{model_name}} success"
          },
          {
            "expr": "sum(rate(inference_calls_failure[5m])) by (model_name)",
            "legendFormat": "{{model_name}} failure"
          }
        ]
      },
      {
        "id": 7,
        "title": "Inference Duration (p90)",
        "type": "graph",
        "gridPos": { "x": 8, "y": 10, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.90, sum(rate(inference_duration_seconds_bucket[5m])) by (model_name, le))",
            "legendFormat": "{{model_name}} p90"
          }
        ],
        "yaxes": [
          { "format": "s" }
        ]
      },
      {
        "id": 8,
        "title": "Token Usage Rate",
        "type": "graph",
        "gridPos": { "x": 16, "y": 10, "w": 8, "h": 6 },
        "targets": [
          {
            "expr": "sum(rate(inference_tokens_input[5m])) by (model_name)",
            "legendFormat": "{{model_name}} input"
          },
          {
            "expr": "sum(rate(inference_tokens_output[5m])) by (model_name)",
            "legendFormat": "{{model_name}} output"
          }
        ]
      },
      {
        "id": 9,
        "title": "Circuit Breaker Status",
        "type": "stat",
        "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
        "targets": [
          {
            "expr": "sum(increase(inference_circuit_breaker_trips_total[5m]))"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      {
        "id": 10,
        "title": "Error Rates",
        "type": "graph",
        "gridPos": { "x": 6, "y": 16, "w": 18, "h": 4 },
        "targets": [
          {
            "expr": "sum(rate(agent_failed_total[5m]))",
            "legendFormat": "Agent Failures"
          },
          {
            "expr": "sum(rate(tool_calls_failure_total[5m]))",
            "legendFormat": "Tool Failures"
          },
          {
            "expr": "sum(rate(inference_calls_failure_total[5m]))",
            "legendFormat": "Inference Failures"
          }
        ]
      },
      {
        "id": 11,
        "title": "JVM Memory Usage",
        "type": "graph",
        "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area='heap'}",
            "legendFormat": "Heap Used"
          },
          {
            "expr": "jvm_memory_max_bytes{area='heap'}",
            "legendFormat": "Heap Max"
          }
        ],
        "yaxes": [
          { "format": "bytes" }
        ]
      },
      {
        "id": 12,
        "title": "GC Pause Time",
        "type": "graph",
        "gridPos": { "x": 12, "y": 20, "w": 12, "h": 6 },
        "targets": [
          {
            "expr": "rate(jvm_gc_pause_seconds_sum[5m]) / rate(jvm_gc_pause_seconds_count[5m])",
            "legendFormat": "Avg GC Pause"
          }
        ],
        "yaxes": [
          { "format": "s" }
        ]
      }
    ]
  }
}

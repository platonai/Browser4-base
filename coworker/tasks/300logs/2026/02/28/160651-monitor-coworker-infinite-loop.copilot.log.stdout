New block:
```bash
        if [ -f "$SCRIPT_PATH" ]; then
            if [ ! -x "$SCRIPT_PATH" ]; then chmod +x "$SCRIPT_PATH"; fi

            # Start in background with monitoring
            TEMP_LOG=$(mktemp)
            "$SCRIPT_PATH" > "$TEMP_LOG" 2>&1 &
            JOB_PID=$!

            # History tracking
            declare -a TIMES
            declare -a LINES_HIST
            declare -a ACTIONS_HIST

            while kill -0 $JOB_PID 2>/dev/null; do
                sleep 30

                CUR_LINES=$(wc -l < "$TEMP_LOG")
                CUR_ACTIONS=$(grep -c "● " "$TEMP_LOG")
                NOW=$(date +%s)

                # Echo new content?
                # Complex to echo only new lines without seeking.
                # Simplest: just monitor silently, maybe tail?
                # Or use `tail -f` in parallel? No.
                # For now, let's skip echoing to stdout to keep it simple, or `cat` at the end.
                # Actually, user might want to see output.
                # But infinite loop prevention is the goal.

                TIMES+=($NOW)
                LINES_HIST+=($CUR_LINES)
                ACTIONS_HIST+=($CUR_ACTIONS)

                # Check 3 mins ago (180 seconds)
                THREE_MINS_AGO=$((NOW - 180))

                # Iterate history to find old point
                FOUND_OLD=false
                OLD_LINES=0
                OLD_ACTIONS=0

                for i in "${!TIMES[@]}"; do
                    if [ "${TIMES[$i]}" -le "$THREE_MINS_AGO" ]; then
                        OLD_LINES=${LINES_HIST[$i]}
                        OLD_ACTIONS=${ACTIONS_HIST[$i]}
                        FOUND_OLD=true
                        # Keep looking for the closest one (latest that is <= 3 mins ago)?
                        # Since we append, the last one matching is the closest.
                    fi
                done

                if [ "$FOUND_OLD" = true ]; then
                    if [ "$CUR_LINES" -gt $((OLD_LINES + 50)) ] && [ "$CUR_ACTIONS" -eq "$OLD_ACTIONS" ]; then
                        echo "Coworker infinite loop detected! Aborting... (Lines: $CUR_LINES, Actions: $CUR_ACTIONS)"
                        kill $JOB_PID

                        ABORTED_DIR="coworker/tasks/3_5aborted"
                        mkdir -p "$ABORTED_DIR"
                        WORKING_DIR="coworker/tasks/2working"

                        if [ -d "$WORKING_DIR" ]; then
                             find "$WORKING_DIR" -maxdepth 1 -type f -print0 | xargs -0 -I {} mv {} "$ABORTED_DIR/"
                             echo "Moved tasks to $ABORTED_DIR"
                        fi
                        break
                    fi
                fi

                # Optional: Prune history? Bash arrays grow.
                # Assuming task doesn't run for days, it's fine.
            done

            wait $JOB_PID 2>/dev/null
            cat "$TEMP_LOG" # Show output at end
            rm "$TEMP_LOG"
            echo "Finished $SCRIPT_NAME execution."
        else
            echo "Error: Script not found at $SCRIPT_PATH"
        fi

{
  "name": "@platonai/browser4-sdk",
  "version": "0.1.0",
  "description": "NodeJS SDK for Browser4 WebDriver-compatible and AgenticSession APIs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "tsc --build --clean",
    "rebuild": "npm run clean && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "prepack": "npm run rebuild",
    "pack:check": "npm pack --dry-run",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "publish:test": "npm publish --dry-run",
    "publish:public": "npm publish --access public",
    "verify": "node scripts/verify-installation.js",
    "verify:build": "node scripts/verify-build.js"
  },
  "keywords": [
    "browser4",
    "web-scraping",
    "browser-automation",
    "webdriver",
    "ai-agent"
  ],
  "author": "Browser4 Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/platonai/Browser4.git",
    "directory": "sdks/browser4-nodejs"
  },
  "bugs": {
    "url": "https://github.com/platonai/Browser4/issues"
  },
  "homepage": "https://github.com/platonai/Browser4/tree/main/sdks/browser4-nodejs",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "stream": "^0.0.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}

# Registry configuration
registry=https://registry.npmjs.org/

# Access level for scoped packages
# Use 'public' for @platonai/browser4-sdk to be publicly available
# Use 'restricted' for private packages
access=public

# Ensure package-lock.json is created
package-lock=true

# Sign git commits and tags
sign-git-commit=false
sign-git-tag=false

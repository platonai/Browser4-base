{
  "name": "@platonai/b4-playwright-cli",
  "version": "0.1.0",
  "description": "Browser4 CLI — control a Browser4 server from the command line",
  "bin": {
    "b4-playwright-cli": "dist/program.js"
  },
  "main": "dist/program.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "tsc --build --clean",
    "rebuild": "npm run clean && npm run build",
    "test": "jest",
    "test:e2e": "npm run build && node ./scripts/run-e2e.js",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "browser4",
    "browser-automation",
    "cli"
  ],
  "author": "Browser4 Team",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/platonai/Browser4.git",
    "directory": "sdks/b4-playwright-cli"
  },
  "bugs": {
    "url": "https://github.com/platonai/Browser4/issues"
  },
  "homepage": "https://github.com/platonai/Browser4/tree/main/sdks/b4-playwright-cli",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "dependencies": {
    "@lowire/loop": "^0.0.26",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.5",
    "debug": "^4.4.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}

<?xml version="1.0" encoding="UTF-8"?>
<!--
  Maven Version Rules for Browser4
  
  This file defines rules for the Maven Versions Plugin to control which
  versions are considered valid updates.
  
  Usage:
    mvnw versions:display-dependency-updates
    mvnw versions:display-plugin-updates
-->
<ruleset comparisonMethod="maven"
         xmlns="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0 
         http://mojo.codehaus.org/versions-maven-plugin/xsd/rule-2.0.0.xsd">

  <!-- 
    Global rules: Ignore pre-release versions for all dependencies
    This prevents suggesting alpha, beta, RC, milestone, and snapshot versions
  -->
  <ignoreVersions>
    <!-- Alpha versions -->
    <ignoreVersion type="regex">.*[-_\.]alpha[-_\.]?[0-9]*</ignoreVersion>
    <ignoreVersion type="regex">.*[-_\.]a[0-9]+</ignoreVersion>
    
    <!-- Beta versions -->
    <ignoreVersion type="regex">.*[-_\.]beta[-_\.]?[0-9]*</ignoreVersion>
    <ignoreVersion type="regex">.*[-_\.]b[0-9]+</ignoreVersion>
    
    <!-- Release Candidate versions -->
    <ignoreVersion type="regex">.*[-_\.]rc[-_\.]?[0-9]*</ignoreVersion>
    <ignoreVersion type="regex">.*[-_\.]cr[-_\.]?[0-9]*</ignoreVersion>
    
    <!-- Milestone versions -->
    <ignoreVersion type="regex">.*[-_\.]M[0-9]+</ignoreVersion>
    <ignoreVersion type="regex">.*[-_\.]milestone[-_\.]?[0-9]*</ignoreVersion>
    
    <!-- Snapshot versions -->
    <ignoreVersion type="regex">.*-SNAPSHOT</ignoreVersion>
    
    <!-- Development versions -->
    <ignoreVersion type="regex">.*[-_\.]dev[-_\.]?[0-9]*</ignoreVersion>
    
    <!-- Nightly builds -->
    <ignoreVersion type="regex">.*[-_\.]nightly[-_\.]?[0-9]*</ignoreVersion>
    
    <!-- Build numbers -->
    <ignoreVersion type="regex">.*[-_\.]build[-_\.]?[0-9]*</ignoreVersion>
  </ignoreVersions>

  <!--
    Dependency-specific rules
    Use these to control upgrades for specific dependencies
  -->
  <rules>
    
    <!-- Apache Lucene: Keep on 7.x until migration plan is executed -->
    <rule groupId="org.apache.lucene" artifactId="*">
      <ignoreVersions>
        <!-- Ignore 8.x and 9.x until we're ready to migrate -->
        <ignoreVersion type="regex">8\..*</ignoreVersion>
        <ignoreVersion type="regex">9\..*</ignoreVersion>
      </ignoreVersions>
    </rule>
    
    <!-- Apache HttpClient: Stay on 4.x for now, 5.x requires migration -->
    <rule groupId="org.apache.httpcomponents" artifactId="httpclient">
      <ignoreVersions>
        <ignoreVersion type="regex">5\..*</ignoreVersion>
      </ignoreVersions>
    </rule>
    
    <!-- Hadoop: Keep current version, consider removal -->
    <rule groupId="org.apache.hadoop" artifactId="*">
      <ignoreVersions>
        <!-- Don't suggest newer versions, we plan to remove this -->
        <ignoreVersion type="regex">3\..*</ignoreVersion>
      </ignoreVersions>
    </rule>
    
    <!-- JGraphT: Keep on 1.x for stability -->
    <rule groupId="org.jgrapht" artifactId="*">
      <ignoreVersions>
        <!-- Review before upgrading to major version -->
        <ignoreVersion type="regex">[2-9]\..*</ignoreVersion>
      </ignoreVersions>
    </rule>
    
    <!-- Kotlin: Allow patch updates, but review minor updates -->
    <rule groupId="org.jetbrains.kotlin" artifactId="*">
      <ignoreVersions>
        <!-- Don't auto-suggest next major version -->
        <ignoreVersion type="regex">3\..*</ignoreVersion>
      </ignoreVersions>
    </rule>
    
    <!-- Spring Boot: Stay on 4.x -->
    <rule groupId="org.springframework.boot" artifactId="*">
      <ignoreVersions>
        <!-- Don't suggest next major version -->
        <ignoreVersion type="regex">5\..*</ignoreVersion>
      </ignoreVersions>
    </rule>
    
    <!-- Commons Collections: Prefer version 4 -->
    <rule groupId="org.apache.commons" artifactId="commons-collections4">
      <ignoreVersions>
        <ignoreVersion type="regex">3\..*</ignoreVersion>
      </ignoreVersions>
    </rule>
    
  </rules>

  <!--
    Notes for maintainers:
    
    1. When planning a major upgrade (e.g., Lucene 7 -> 9), temporarily 
       remove or modify the corresponding rule to see available versions.
    
    2. Pre-release versions are globally ignored, but you can allow them
       for specific dependencies by adding a rule with allowSnapshots="true"
    
    3. To see all versions including ignored ones, use:
       mvnw versions:display-dependency-updates -DallowSnapshots=true
    
    4. This file should be reviewed and updated quarterly or when planning
       major version upgrades.
  -->

</ruleset>
